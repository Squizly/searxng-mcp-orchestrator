# --- LLM провайдер ---
# Варианты: direct, ollama, openrouter
LLM_PROVIDER=ollama

# --- Ollama (локальная модель) ---
OLLAMA_MODEL_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama3.2

# --- OpenRouter ---
# Актуально только если LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api

# --- SearxNG ---
# Список инстансов через запятую (первый используется по умолчанию)
SEARXNG_INSTANCES=http://localhost:8080
SEARXNG_DEFAULT_LANGUAGE=ru
SEARXNG_DEFAULT_CATEGORIES=general
REQUEST_TIMEOUT=10
SEARXNG_PARALLELISM=3
LLM_TIMEOUT=120

# --- Логирование ---
LOG_LEVEL=INFO
LOG_CONSOLE_LEVEL=INFO
LOG_FILE=logs/results.log
